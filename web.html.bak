<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>PagooTalk</title>
<script src="https://cdn.jsdelivr.net/npm/simple-peer@9.11.1/simplepeer.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg-primary: #17212b;
  --bg-secondary: #0e1621;
  --bg-sidebar: #17212b;
  --bg-chat: #0e1621;
  --bg-message-out: #2b5278;
  --bg-message-in: #182533;
  --bg-input: #17212b;
  --bg-hover: #202b36;
  --bg-active: #2b5278;
  --accent: #5288c1;
  --accent-hover: #6ba1d6;
  --text-primary: #f5f5f5;
  --text-secondary: #708499;
  --text-muted: #52667a;
  --online: #4dcd5e;
  --danger: #e53935;
  --border: rgba(255,255,255,0.06);
  --border-focus: #5288c1;
  --drawer-width: 280px;
  --panel-width: 360px;
  --sidebar-width: 340px;
}

* { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', system-ui, -apple-system, sans-serif; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; overflow: hidden; background: var(--bg-secondary); }
body { display: flex; justify-content: center; align-items: center; color: var(--text-primary); }

/* Animations */
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideRight { from { transform: translateX(-100%); } to { transform: translateX(0); } }
@keyframes slideLeft { from { transform: translateX(100%); } to { transform: translateX(0); } }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

/* Icon system */
.icon { display: inline-flex; align-items: center; justify-content: center; line-height: 0; }
.icon svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
.icon-sm svg { width: 16px; height: 16px; }
.icon-lg svg { width: 24px; height: 24px; }
.icon-xl svg { width: 28px; height: 28px; }

/* Drawer overlay */
.drawer-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.5); z-index: 300;
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s ease;
}
.drawer-overlay.active { opacity: 1; pointer-events: all; }

/* Drawer */
.drawer {
  position: fixed; top: 0; left: 0; width: var(--drawer-width); height: 100%;
  background: var(--bg-sidebar); z-index: 301;
  transform: translateX(-100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex; flex-direction: column;
  border-right: 1px solid var(--border);
}
.drawer.active { transform: translateX(0); }

.drawer-profile {
  padding: 20px; background: linear-gradient(135deg, #1a2a3a 0%, #17212b 100%);
  border-bottom: 1px solid var(--border);
}
.drawer-profile .avatar {
  width: 56px; height: 56px; font-size: 1.3rem; margin-bottom: 12px;
  background: linear-gradient(135deg, var(--accent), #6ba1d6);
}
.drawer-profile-name { font-weight: 600; font-size: 0.95rem; color: var(--text-primary); }
.drawer-profile-username { font-size: 0.8rem; color: var(--text-secondary); margin-top: 2px; }
.drawer-profile-edit {
  position: absolute; top: 20px; right: 16px;
  background: none; border: none; color: var(--text-secondary); cursor: pointer;
  width: 32px; height: 32px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.drawer-profile-edit:hover { background: var(--bg-hover); color: var(--accent); }

.drawer-menu { flex: 1; overflow-y: auto; padding: 8px 0; }
.drawer-menu-item {
  display: flex; align-items: center; gap: 16px;
  padding: 12px 20px; cursor: pointer;
  color: var(--text-primary); font-size: 0.9rem;
  transition: background 0.15s ease;
  border: none; background: none; width: 100%; text-align: left;
}
.drawer-menu-item:hover { background: var(--bg-hover); }
.drawer-menu-item .icon { color: var(--text-secondary); }
.drawer-menu-item:hover .icon { color: var(--accent); }
.drawer-menu-item .chevron { margin-left: auto; color: var(--text-muted); }

/* Right panel (profile / settings) */
.panel-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.4); z-index: 400;
  opacity: 0; pointer-events: none;
  transition: opacity 0.3s ease;
}
.panel-overlay.active { opacity: 1; pointer-events: all; }

.panel {
  position: fixed; top: 0; right: 0; width: var(--panel-width); height: 100%;
  background: var(--bg-sidebar); z-index: 401;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex; flex-direction: column;
  border-left: 1px solid var(--border);
  max-width: 100vw;
}
.panel.active { transform: translateX(0); }

.panel-header {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 16px; border-bottom: 1px solid var(--border);
  background: var(--bg-primary); flex-shrink: 0;
}
.panel-header .back-btn {
  background: none; border: none; color: var(--accent); cursor: pointer;
  width: 36px; height: 36px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s;
}
.panel-header .back-btn:hover { background: var(--bg-hover); }
.panel-header h3 { font-size: 1rem; font-weight: 600; }

.panel-body { flex: 1; overflow-y: auto; padding: 20px; }

/* Profile panel */
.profile-avatar-section {
  display: flex; flex-direction: column; align-items: center; margin-bottom: 24px;
}
.profile-avatar-large {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), #6ba1d6);
  display: flex; align-items: center; justify-content: center;
  font-size: 2rem; font-weight: 700; color: #fff;
  overflow: hidden; position: relative; cursor: pointer;
  margin-bottom: 8px;
}
.profile-avatar-large img { width: 100%; height: 100%; object-fit: cover; }
.profile-avatar-edit-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.2s; border-radius: 50%;
}
.profile-avatar-large:hover .profile-avatar-edit-overlay { opacity: 1; }

.profile-field { margin-bottom: 16px; }
.profile-field label { display: block; font-size: 0.75rem; color: var(--accent); margin-bottom: 4px; font-weight: 500; }
.profile-field input, .profile-field textarea {
  width: 100%; padding: 10px 12px; background: var(--bg-secondary);
  border: 1px solid var(--border); border-radius: 8px;
  color: var(--text-primary); font-size: 0.9rem; outline: none;
  transition: border-color 0.2s;
}
.profile-field input:focus, .profile-field textarea:focus { border-color: var(--border-focus); }
.profile-field textarea { resize: vertical; min-height: 60px; font-family: inherit; }
.profile-field .field-hint { font-size: 0.72rem; color: var(--text-muted); margin-top: 4px; }

.profile-link-section {
  margin-top: 20px; padding: 16px; background: var(--bg-secondary);
  border-radius: 12px; border: 1px solid var(--border);
}
.profile-link-section h4 { font-size: 0.85rem; color: var(--text-primary); margin-bottom: 8px; }
.profile-link-section p { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 12px; }
.profile-link-row { display: flex; gap: 8px; }
.profile-link-row input { flex: 1; padding: 8px 12px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 8px; color: var(--text-secondary); font-size: 0.78rem; }

.btn-primary {
  padding: 8px 16px; background: var(--accent); color: #fff; border: none;
  border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 500;
  transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
}
.btn-primary:hover { background: var(--accent-hover); }
.btn-primary:active { transform: scale(0.97); }

.btn-secondary {
  padding: 8px 16px; background: var(--bg-hover); color: var(--text-primary); border: none;
  border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 500;
  transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
}
.btn-secondary:hover { background: var(--bg-active); }

.btn-danger {
  padding: 8px 16px; background: var(--danger); color: #fff; border: none;
  border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 500;
  transition: all 0.2s;
}
.btn-danger:hover { background: #c62828; }

.profile-technical-id {
  margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--border);
}
.profile-technical-id span { font-size: 0.68rem; color: var(--text-muted); font-family: 'Consolas', 'Monaco', monospace; }

.profile-save-bar {
  padding: 12px 20px; border-top: 1px solid var(--border);
  background: var(--bg-primary); display: flex; justify-content: flex-end;
}

/* Settings panel */
.settings-category {
  margin-bottom: 4px;
}
.settings-category-header {
  display: flex; align-items: center; gap: 14px;
  padding: 12px 0; cursor: pointer; width: 100%;
  background: none; border: none; color: var(--text-primary);
  font-size: 0.9rem; border-bottom: 1px solid var(--border);
  transition: color 0.15s;
}
.settings-category-header:hover { color: var(--accent); }
.settings-category-header .icon { color: var(--text-secondary); flex-shrink: 0; }
.settings-category-header .chevron { margin-left: auto; color: var(--text-muted); transition: transform 0.2s; }
.settings-category-header.expanded .chevron { transform: rotate(90deg); }
.settings-category-body {
  max-height: 0; overflow: hidden;
  transition: max-height 0.3s ease;
  padding-left: 34px;
}
.settings-category-body.expanded { max-height: 500px; }

.settings-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 0; border-bottom: 1px solid var(--border);
}
.settings-item:last-child { border-bottom: none; }
.settings-item-label { font-size: 0.85rem; color: var(--text-primary); }
.settings-item-desc { font-size: 0.72rem; color: var(--text-muted); margin-top: 2px; }

/* Toggle switch */
.toggle-switch {
  position: relative; width: 40px; height: 22px; flex-shrink: 0;
}
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider {
  position: absolute; cursor: pointer; inset: 0;
  background: var(--text-muted); border-radius: 22px;
  transition: all 0.25s;
}
.toggle-slider::before {
  content: ''; position: absolute; width: 18px; height: 18px;
  left: 2px; bottom: 2px; background: #fff;
  border-radius: 50%; transition: transform 0.25s;
}
.toggle-switch input:checked + .toggle-slider { background: var(--accent); }
.toggle-switch input:checked + .toggle-slider::before { transform: translateX(18px); }

/* App container */
.app-container {
  width: 100%; max-width: 1440px; height: 100vh;
  display: flex; overflow: hidden; position: relative;
  background: var(--bg-primary);
  animation: fadeIn 0.4s ease-out;
}

/* Sidebar */
.sidebar {
  width: var(--sidebar-width); display: flex; flex-direction: column;
  position: relative; z-index: 1;
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border);
  flex-shrink: 0;
}

.sidebar-header {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 12px; min-height: 56px;
}
.hamburger-btn {
  width: 40px; height: 40px; border-radius: 50%;
  background: none; border: none; color: var(--text-secondary);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.hamburger-btn:hover { background: var(--bg-hover); color: var(--accent); }

.sidebar-search {
  flex: 1; position: relative;
}
.sidebar-search input {
  width: 100%; padding: 8px 12px 8px 36px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  border-radius: 20px; color: var(--text-primary); font-size: 0.85rem; outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.sidebar-search input:focus { border-color: var(--border-focus); box-shadow: 0 0 0 2px rgba(82,136,193,0.15); }
.sidebar-search input::placeholder { color: var(--text-muted); }
.sidebar-search .search-icon-left {
  position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
  color: var(--text-muted); pointer-events: none;
}

.chat-list { flex: 1; overflow-y: auto; }

.chat-item {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 12px; cursor: pointer;
  transition: background 0.15s ease;
  border-left: 3px solid transparent;
}
.chat-item:hover { background: var(--bg-hover); }
.chat-item.active { background: var(--bg-active); border-left-color: var(--accent); }

.chat-item-avatar {
  width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, var(--accent), #6ba1d6);
  display: flex; align-items: center; justify-content: center;
  font-weight: 600; font-size: 1rem; color: #fff;
  overflow: hidden; position: relative;
}
.chat-item-avatar img { width: 100%; height: 100%; object-fit: cover; }
.chat-item-avatar .online-dot {
  position: absolute; bottom: 1px; right: 1px;
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--online); border: 2px solid var(--bg-sidebar);
}
.chat-item-avatar .offline-dot {
  position: absolute; bottom: 1px; right: 1px;
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--text-muted); border: 2px solid var(--bg-sidebar);
}

.chat-item-content { flex: 1; overflow: hidden; min-width: 0; }
.chat-item-top { display: flex; justify-content: space-between; align-items: baseline; }
.chat-item-name { font-weight: 600; font-size: 0.88rem; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.chat-item-time { font-size: 0.7rem; color: var(--text-muted); flex-shrink: 0; margin-left: 8px; }
.chat-item-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 3px; }
.chat-item-preview { font-size: 0.78rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }
.unread-badge {
  background: var(--accent); color: #fff; font-size: 0.65rem; font-weight: 700;
  min-width: 20px; height: 20px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  padding: 0 6px; flex-shrink: 0; margin-left: 8px;
}

/* Chat area */
.chat-area {
  flex: 1; display: flex; flex-direction: column;
  position: relative; z-index: 1;
  background: var(--bg-chat);
  min-width: 0;
}

.chat-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 16px; min-height: 56px;
  background: var(--bg-primary);
  border-bottom: 1px solid var(--border);
}
.chat-header-left {
  display: flex; align-items: center; gap: 12px; cursor: pointer;
  flex: 1; overflow: hidden; min-width: 0;
}
.chat-header-avatar {
  width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, var(--accent), #6ba1d6);
  display: flex; align-items: center; justify-content: center;
  font-weight: 600; font-size: 0.9rem; color: #fff;
  overflow: hidden;
}
.chat-header-avatar img { width: 100%; height: 100%; object-fit: cover; }
.chat-header-info { overflow: hidden; min-width: 0; }
.chat-header-name { font-weight: 600; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.chat-header-status { font-size: 0.75rem; color: var(--text-secondary); }

.chat-header-actions { display: flex; gap: 4px; flex-shrink: 0; }

.icon-btn {
  width: 40px; height: 40px; border-radius: 50%;
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  background: transparent; color: var(--text-secondary);
  transition: all 0.2s;
}
.icon-btn:hover { background: var(--bg-hover); color: var(--accent); }
.icon-btn:active { transform: scale(0.92); }
.icon-btn.active { color: var(--accent); background: rgba(82,136,193,0.1); }

.spam-warning {
  padding: 8px 16px; background: rgba(245,158,11,0.1);
  border-bottom: 1px solid rgba(245,158,11,0.2);
  color: #f59e0b; font-size: 0.8rem; text-align: center;
  display: none;
}
.spam-warning.active { display: block; animation: fadeIn 0.3s; }

.chat-messages {
  flex: 1; padding: 16px 60px; overflow-y: auto;
  display: flex; flex-direction: column;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.015'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.message-bubble {
  max-width: 65%; padding: 8px 12px; border-radius: 12px;
  animation: slideUp 0.25s ease-out; position: relative;
  word-wrap: break-word; margin-bottom: 4px;
  align-self: flex-end;
  background: var(--bg-message-out); color: var(--text-primary);
}
.message-bubble.incoming {
  align-self: flex-start;
  background: var(--bg-message-in);
}
.message-bubble .sender-name { font-size: 0.72rem; color: var(--accent); font-weight: 600; margin-bottom: 2px; }
.message-bubble .msg-text { font-size: 0.88rem; line-height: 1.45; }
.message-bubble .msg-time { font-size: 0.65rem; color: var(--text-muted); margin-top: 4px; text-align: right; }

.voice-msg {
  display: flex; align-items: center; gap: 10px; min-width: 180px;
}
.voice-msg .play-btn {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--accent); color: #fff; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; flex-shrink: 0;
}
.voice-msg .play-btn:hover { background: var(--accent-hover); }
.voice-msg .voice-wave { flex: 1; height: 24px; background: rgba(255,255,255,0.1); border-radius: 4px; position: relative; overflow: hidden; }
.voice-msg .voice-duration { font-size: 0.72rem; color: var(--text-muted); flex-shrink: 0; }

.file-msg {
  display: flex; align-items: center; gap: 10px; padding: 6px 0;
}
.file-msg .file-icon-box {
  width: 36px; height: 36px; border-radius: 8px;
  background: rgba(82,136,193,0.15); color: var(--accent);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.file-msg .file-info { flex: 1; overflow: hidden; min-width: 0; }
.file-msg .file-name { font-weight: 500; font-size: 0.82rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.file-msg .file-size { font-size: 0.7rem; color: var(--text-muted); }
.file-msg .file-download-btn {
  padding: 4px 10px; background: var(--accent); color: #fff; border: none;
  border-radius: 6px; cursor: pointer; font-size: 0.75rem; flex-shrink: 0;
  transition: background 0.2s;
}
.file-msg .file-download-btn:hover { background: var(--accent-hover); }

.empty-state {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 100%; text-align: center; padding: 40px;
}
.empty-state .empty-icon { color: var(--text-muted); margin-bottom: 16px; opacity: 0.5; }
.empty-state h3 { font-size: 1.1rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 8px; }
.empty-state p { font-size: 0.85rem; color: var(--text-muted); }

/* Chat input */
.chat-input-area {
  display: flex; align-items: flex-end; gap: 8px;
  padding: 10px 16px; background: var(--bg-primary);
  border-top: 1px solid var(--border);
}
.chat-input-wrapper {
  flex: 1; display: flex; align-items: flex-end;
  background: var(--bg-input); border: 1px solid var(--border);
  border-radius: 20px; padding: 4px 8px 4px 12px;
  transition: border-color 0.2s;
}
.chat-input-wrapper:focus-within { border-color: var(--border-focus); }
.chat-input-wrapper input {
  flex: 1; background: transparent; border: none; padding: 8px 0;
  color: var(--text-primary); font-size: 0.9rem; outline: none;
}
.chat-input-wrapper input::placeholder { color: var(--text-muted); }

.send-btn {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--accent); color: #fff; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s; flex-shrink: 0;
}
.send-btn:hover { background: var(--accent-hover); }
.send-btn:active { transform: scale(0.92); }
.send-btn.recording { background: var(--danger); animation: pulse 1.5s infinite; }

/* Call overlay */
#group-call-overlay {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(14,22,33,0.98); z-index: 100;
  display: none; flex-direction: column;
}
#group-call-overlay.active { display: flex; animation: fadeIn 0.3s ease-out; }

.call-main-area { flex: 1; display: flex; flex-direction: column; }
.call-top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 20px;
}
.call-top-bar h3 { color: var(--text-primary); font-size: 1rem; }

.call-grid {
  flex: 1; display: flex; flex-wrap: wrap; gap: 12px; padding: 16px;
  justify-content: center; align-items: center; align-content: center;
  overflow-y: auto;
}
.video-tile {
  background: var(--bg-secondary); border-radius: 12px; overflow: hidden;
  position: relative; width: 48%; min-width: 200px; max-width: 500px;
  border: 1px solid var(--border);
}
.video-tile video { width: 100%; height: 100%; object-fit: cover; min-height: 180px; background: #000; }
.video-tile .participant-name {
  position: absolute; bottom: 10px; left: 10px;
  background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
  color: #fff; padding: 4px 10px; border-radius: 6px;
  font-size: 0.8rem; font-weight: 500;
}
.video-tile .screen-share-badge {
  position: absolute; top: 10px; right: 10px;
  background: var(--danger); color: #fff;
  padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600;
}

.call-sidebar {
  background: var(--bg-primary); border-top: 1px solid var(--border);
  padding: 12px 16px; max-height: 160px; overflow-y: auto;
}
.call-sidebar h4 { font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 8px; }
.participant-item {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 8px; border-radius: 6px; margin-bottom: 4px;
  font-size: 0.82rem;
}
.participant-item .avatar { width: 28px; height: 28px; font-size: 0.7rem; }

.call-controls-bar {
  display: flex; justify-content: center; gap: 12px;
  padding: 16px; background: var(--bg-primary);
  border-top: 1px solid var(--border);
}
.control-btn {
  width: 48px; height: 48px; border-radius: 50%;
  border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.08); color: var(--text-primary);
  transition: all 0.2s;
}
.control-btn:hover { background: rgba(255,255,255,0.15); transform: scale(1.08); }
.control-btn:active { transform: scale(0.95); }
.control-btn.muted { background: var(--danger); color: #fff; }
.control-btn.danger { background: var(--danger); color: #fff; }
.control-btn.danger:hover { background: #c62828; }

/* Modals */
.modal-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.55); z-index: 500;
  display: none; align-items: center; justify-content: center;
}
.modal-overlay.active { display: flex; animation: fadeIn 0.2s ease; }

.modal {
  background: var(--bg-primary); padding: 0; border-radius: 12px;
  width: 90%; max-width: 400px; max-height: 85vh; overflow-y: auto;
  border: 1px solid var(--border);
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px; border-bottom: 1px solid var(--border);
}
.modal-header h3 { font-size: 1rem; font-weight: 600; }
.modal-close {
  width: 32px; height: 32px; border-radius: 50%;
  background: none; border: none; color: var(--text-secondary);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
}
.modal-close:hover { background: var(--bg-hover); color: var(--text-primary); }

.modal-body { padding: 20px; }

.modal-tabs {
  display: flex; border-bottom: 1px solid var(--border);
}
.modal-tab {
  flex: 1; padding: 12px; text-align: center; cursor: pointer;
  font-size: 0.85rem; font-weight: 500;
  color: var(--text-secondary); background: none; border: none;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}
.modal-tab:hover { color: var(--text-primary); }
.modal-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

.tab-content { display: none; }
.tab-content.active { display: block; }

.modal-field { margin-bottom: 14px; }
.modal-field label { display: block; font-size: 0.78rem; color: var(--text-secondary); margin-bottom: 6px; }
.modal-field input, .modal-field textarea {
  width: 100%; padding: 10px 12px;
  background: var(--bg-secondary); border: 1px solid var(--border);
  border-radius: 8px; color: var(--text-primary); font-size: 0.88rem;
  outline: none; transition: border-color 0.2s;
}
.modal-field input:focus, .modal-field textarea:focus { border-color: var(--border-focus); }
.modal-field input::placeholder, .modal-field textarea::placeholder { color: var(--text-muted); }

.invite-code-display {
  margin-top: 12px; padding: 10px; background: var(--bg-secondary);
  border: 1px solid var(--border); border-radius: 8px;
  font-size: 0.72rem; color: var(--text-secondary);
  word-break: break-all; font-family: 'Consolas', 'Monaco', monospace;
  max-height: 80px; overflow-y: auto;
  display: none;
}
.invite-code-display.active { display: block; }

.error-text { color: var(--danger); font-size: 0.8rem; margin-bottom: 8px; display: none; }
.success-text { color: var(--online); font-size: 0.8rem; margin-bottom: 8px; display: none; }

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

/* Responsive */
@media (max-width: 768px) {
  .sidebar { width: 100%; position: absolute; z-index: 10; height: 100%; }
  .chat-area { width: 100%; }
  .sidebar.hidden-mobile { display: none; }
  .chat-area.hidden-mobile { display: none; }
  .chat-messages { padding: 16px 20px; }
  .message-bubble { max-width: 85%; }
  .video-tile { width: 100%; min-width: unset; }
  .panel { width: 100vw; }
  .mobile-back-btn { display: flex !important; }
}
@media (min-width: 769px) {
  .mobile-back-btn { display: none !important; }
}
</style>
</head>
<body>

<!-- Drawer Overlay -->
<div class="drawer-overlay" id="drawer-overlay"></div>

<!-- Drawer -->
<div class="drawer" id="drawer">
  <div class="drawer-profile" style="position:relative;">
    <div class="avatar" id="drawer-avatar" style="width:56px;height:56px;font-size:1.3rem;border-radius:50%;background:linear-gradient(135deg,var(--accent),#6ba1d6);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;overflow:hidden;">?</div>
    <div class="drawer-profile-name" id="drawer-name">Пользователь</div>
    <div class="drawer-profile-username" id="drawer-username">@user</div>
    <button class="drawer-profile-edit" id="drawer-edit-profile" title="Редактировать профиль">
      <span class="icon icon-sm" id="drawer-edit-icon"></span>
    </button>
  </div>
  <div class="drawer-menu">
    <button class="drawer-menu-item" id="drawer-new-chat">
      <span class="icon" id="drawer-newchat-icon"></span>
      <span>Новый чат</span>
      <span class="icon icon-sm chevron" id="drawer-newchat-chevron"></span>
    </button>
    <button class="drawer-menu-item" id="drawer-new-group">
      <span class="icon" id="drawer-group-icon"></span>
      <span>Новая группа</span>
      <span class="icon icon-sm chevron" id="drawer-group-chevron"></span>
    </button>
    <button class="drawer-menu-item" id="drawer-profile">
      <span class="icon" id="drawer-profile-icon"></span>
      <span>Профиль</span>
      <span class="icon icon-sm chevron" id="drawer-profile-chevron"></span>
    </button>
    <button class="drawer-menu-item" id="drawer-settings">
      <span class="icon" id="drawer-settings-icon"></span>
      <span>Настройки</span>
      <span class="icon icon-sm chevron" id="drawer-settings-chevron"></span>
    </button>
    <button class="drawer-menu-item" id="drawer-about">
      <span class="icon" id="drawer-about-icon"></span>
      <span>О приложении</span>
      <span class="icon icon-sm chevron" id="drawer-about-chevron"></span>
    </button>
  </div>
</div>

<!-- Profile Panel Overlay -->
<div class="panel-overlay" id="profile-panel-overlay"></div>

<!-- Profile Panel -->
<div class="panel" id="profile-panel">
  <div class="panel-header">
    <button class="back-btn" id="close-profile-panel">
      <span class="icon" id="profile-back-icon"></span>
    </button>
    <h3>Профиль</h3>
  </div>
  <div class="panel-body">
    <div class="profile-avatar-section">
      <div class="profile-avatar-large" id="profile-avatar-large" title="Нажмите для смены аватарки">
        ?
        <div class="profile-avatar-edit-overlay">
          <span class="icon icon-lg" style="color:#fff;" id="profile-camera-icon"></span>
        </div>
      </div>
      <input type="file" id="avatar-input" accept="image/*" style="display:none;">
    </div>
    <div class="profile-field">
      <label>Имя</label>
      <input type="text" id="profile-first-name" placeholder="Ваше имя">
    </div>
    <div class="profile-field">
      <label>Фамилия</label>
      <input type="text" id="profile-last-name" placeholder="Ваша фамилия">
    </div>
    <div class="profile-field">
      <label>Юзернейм</label>
      <input type="text" id="profile-username" placeholder="username (без @)" maxlength="30">
      <div class="field-hint">Буквы, цифры и подчёркивания, 2-30 символов</div>
    </div>
    <div class="profile-field">
      <label>О себе</label>
      <textarea id="profile-bio" placeholder="Расскажите о себе..." maxlength="200"></textarea>
    </div>
    <div class="profile-link-section">
      <h4>Ваша ссылка для связи</h4>
      <p>Поделитесь этой ссылкой, чтобы другие могли написать вам</p>
      <div class="profile-link-row">
        <input type="text" id="profile-share-link" readonly placeholder="Нажмите &quot;Создать ссылку&quot;">
        <button class="btn-primary" id="profile-copy-link">
          <span class="icon icon-sm" id="profile-copy-icon"></span>
          <span>Копировать</span>
        </button>
      </div>
    </div>
    <p class="error-text" id="profile-error"></p>
    <p class="success-text" id="profile-success">Профиль сохранён!</p>
    <div class="profile-technical-id">
      <span>Технический ID: <span id="profile-tech-id">...</span></span>
    </div>
  </div>
  <div class="profile-save-bar">
    <button class="btn-primary" id="save-profile-btn">Сохранить</button>
  </div>
</div>

<!-- Settings Panel Overlay -->
<div class="panel-overlay" id="settings-panel-overlay"></div>

<!-- Settings Panel -->
<div class="panel" id="settings-panel">
  <div class="panel-header">
    <button class="back-btn" id="close-settings-panel">
      <span class="icon" id="settings-back-icon"></span>
    </button>
    <h3>Настройки</h3>
  </div>
  <div class="panel-body">
    <!-- General -->
    <div class="settings-category">
      <button class="settings-category-header" data-category="general">
        <span class="icon" id="settings-palette-icon"></span>
        <span>Общие</span>
        <span class="icon icon-sm chevron" id="settings-general-chevron"></span>
      </button>
      <div class="settings-category-body" id="settings-general-body">
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Тёмная тема</div>
            <div class="settings-item-desc">Включена по умолчанию</div>
          </div>
          <label class="toggle-switch"><input type="checkbox" checked disabled><span class="toggle-slider"></span></label>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Язык</div>
            <div class="settings-item-desc">Русский</div>
          </div>
          <span style="color:var(--text-muted);font-size:0.8rem;">Скоро</span>
        </div>
      </div>
    </div>

    <!-- Notifications -->
    <div class="settings-category">
      <button class="settings-category-header" data-category="notifications">
        <span class="icon" id="settings-bell-icon"></span>
        <span>Уведомления</span>
        <span class="icon icon-sm chevron" id="settings-notif-chevron"></span>
      </button>
      <div class="settings-category-body" id="settings-notifications-body">
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Звук сообщений</div>
          </div>
          <label class="toggle-switch"><input type="checkbox" checked id="setting-msg-sound"><span class="toggle-slider"></span></label>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Уведомления</div>
          </div>
          <label class="toggle-switch"><input type="checkbox" checked id="setting-notifications"><span class="toggle-slider"></span></label>
        </div>
      </div>
    </div>

    <!-- Privacy -->
    <div class="settings-category">
      <button class="settings-category-header" data-category="privacy">
        <span class="icon" id="settings-shield-icon"></span>
        <span>Конфиденциальность</span>
        <span class="icon icon-sm chevron" id="settings-privacy-chevron"></span>
      </button>
      <div class="settings-category-body" id="settings-privacy-body">
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Показывать технический ID</div>
            <div class="settings-item-desc">Отображать ID в профиле</div>
          </div>
          <label class="toggle-switch"><input type="checkbox" id="setting-show-id"><span class="toggle-slider"></span></label>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Очистить историю чатов</div>
            <div class="settings-item-desc">Удалить все сообщения</div>
          </div>
          <button class="btn-danger" id="setting-clear-history" style="font-size:0.75rem;padding:6px 12px;">Очистить</button>
        </div>
      </div>
    </div>

    <!-- Chat Settings -->
    <div class="settings-category">
      <button class="settings-category-header" data-category="chat">
        <span class="icon" id="settings-msg-icon"></span>
        <span>Чат</span>
        <span class="icon icon-sm chevron" id="settings-chat-chevron"></span>
      </button>
      <div class="settings-category-body" id="settings-chat-body">
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Предпросмотр сообщений</div>
          </div>
          <label class="toggle-switch"><input type="checkbox" checked id="setting-msg-preview"><span class="toggle-slider"></span></label>
        </div>
      </div>
    </div>

    <!-- Storage -->
    <div class="settings-category">
      <button class="settings-category-header" data-category="storage">
        <span class="icon" id="settings-hdd-icon"></span>
        <span>Хранилище</span>
        <span class="icon icon-sm chevron" id="settings-storage-chevron"></span>
      </button>
      <div class="settings-category-body" id="settings-storage-body">
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Использовано</div>
            <div class="settings-item-desc" id="settings-storage-usage">Расчёт...</div>
          </div>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Очистить кэш</div>
            <div class="settings-item-desc">Удалить кэшированные данные</div>
          </div>
          <button class="btn-secondary" id="setting-clear-cache" style="font-size:0.75rem;padding:6px 12px;">Очистить</button>
        </div>
      </div>
    </div>

    <!-- About -->
    <div class="settings-category">
      <button class="settings-category-header" data-category="about">
        <span class="icon" id="settings-info-icon"></span>
        <span>О приложении</span>
        <span class="icon icon-sm chevron" id="settings-about-chevron"></span>
      </button>
      <div class="settings-category-body" id="settings-about-body">
        <div class="settings-item">
          <div>
            <div class="settings-item-label">PagooTalk</div>
            <div class="settings-item-desc">P2P мессенджер v1.0</div>
          </div>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item-label">Технологии</div>
            <div class="settings-item-desc">WebRTC, SimplePeer, P2P</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- New Chat Modal -->
<div class="modal-overlay" id="new-chat-modal">
  <div class="modal">
    <div class="modal-header">
      <h3>Новый чат</h3>
      <button class="modal-close" id="close-new-chat-modal">
        <span class="icon icon-sm" id="newchat-close-icon"></span>
      </button>
    </div>
    <div class="modal-tabs">
      <button class="modal-tab active" data-tab="connect">Подключиться</button>
      <button class="modal-tab" data-tab="share">Поделиться</button>
    </div>
    <div class="modal-body">
      <div class="tab-content active" id="tab-connect">
        <div class="modal-field">
          <label>Вставьте ссылку или код собеседника</label>
          <input type="text" id="connect-code-input" placeholder="Вставьте код приглашения...">
        </div>
        <p class="error-text" id="connect-error"></p>
        <button class="btn-primary" style="width:100%;justify-content:center;" id="connect-btn">
          <span class="icon icon-sm" id="connect-link-icon"></span>
          Подключиться
        </button>
      </div>
      <div class="tab-content" id="tab-share">
        <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:14px;">Поделитесь этой ссылкой с собеседником, чтобы он мог вам написать</p>
        <div class="invite-code-display" id="share-invite-code"></div>
        <button class="btn-primary" style="width:100%;justify-content:center;margin-top:12px;" id="share-copy-btn">
          <span class="icon icon-sm" id="share-copy-icon"></span>
          Копировать ссылку
        </button>
        <p style="font-size:0.75rem;color:var(--text-muted);margin-top:12px;text-align:center;">Сначала создайте чат, чтобы получить ссылку для приглашения</p>
      </div>
    </div>
  </div>
</div>

<!-- Group Modal -->
<div class="modal-overlay" id="group-modal">
  <div class="modal">
    <div class="modal-header">
      <h3>Новая группа</h3>
      <button class="modal-close" id="close-group-modal">
        <span class="icon icon-sm" id="group-close-icon"></span>
      </button>
    </div>
    <div class="modal-body">
      <div class="modal-field">
        <label>Название группы</label>
        <input type="text" id="group-name" placeholder="Введите название...">
      </div>
      <button class="btn-primary" style="width:100%;justify-content:center;" id="create-group-btn">
        <span class="icon icon-sm" id="group-plus-icon"></span>
        Создать группу
      </button>
      <div class="invite-code-display" id="group-invite-code"></div>
    </div>
  </div>
</div>

<!-- About Modal -->
<div class="modal-overlay" id="about-modal">
  <div class="modal">
    <div class="modal-header">
      <h3>О приложении</h3>
      <button class="modal-close" id="close-about-modal">
        <span class="icon icon-sm" id="about-close-icon"></span>
      </button>
    </div>
    <div class="modal-body" style="text-align:center;">
      <div style="margin-bottom:16px;">
        <span class="icon icon-xl" style="color:var(--accent);" id="about-logo-icon"></span>
      </div>
      <h3 style="margin-bottom:8px;">PagooTalk</h3>
      <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:4px;">P2P мессенджер v1.0</p>
      <p style="font-size:0.78rem;color:var(--text-muted);margin-bottom:16px;">Безопасное общение на основе WebRTC</p>
      <p style="font-size:0.75rem;color:var(--text-muted);">Сквозное шифрование | Без серверов | Открытый код</p>
    </div>
  </div>
</div>

<!-- Main App -->
<div class="app-container">
  <!-- Sidebar -->
  <div class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <button class="hamburger-btn" id="hamburger-btn" title="Меню">
        <span class="icon icon-lg" id="hamburger-icon"></span>
      </button>
      <div class="sidebar-search">
        <span class="icon icon-sm search-icon-left" id="sidebar-search-icon"></span>
        <input type="text" id="contact-search-input" placeholder="Поиск...">
      </div>
    </div>
    <div class="chat-list" id="chat-list"></div>
  </div>

  <!-- Chat Area -->
  <div class="chat-area" id="chat-area">
    <div class="chat-header">
      <div class="chat-header-left" id="chat-header-left">
        <button class="icon-btn mobile-back-btn" id="mobile-back-btn" style="display:none;">
          <span class="icon" id="mobile-back-icon"></span>
        </button>
        <div class="chat-header-avatar" id="chat-header-avatar">?</div>
        <div class="chat-header-info">
          <div class="chat-header-name" id="current-chat-name">PagooTalk</div>
          <div class="chat-header-status" id="chat-header-status">Выберите чат</div>
        </div>
      </div>
      <div class="chat-header-actions">
        <button class="icon-btn" id="btn-call-audio" title="Аудиозвонок">
          <span class="icon" id="btn-audio-icon"></span>
        </button>
        <button class="icon-btn" id="btn-call-video" title="Видеозвонок">
          <span class="icon" id="btn-video-icon"></span>
        </button>
        <button class="icon-btn" id="btn-chat-search" title="Поиск по сообщениям">
          <span class="icon" id="btn-search-icon"></span>
        </button>
      </div>
    </div>

    <div class="spam-warning" id="spam-warning">Слишком много сообщений. Подождите немного...</div>

    <div class="chat-messages" id="chat-messages">
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">
          <span class="icon icon-xl" id="empty-chat-icon"></span>
        </div>
        <h3>Добро пожаловать в PagooTalk</h3>
        <p>Выберите чат или создайте новый</p>
      </div>
    </div>

    <!-- Message search bar (hidden by default) -->
    <div id="msg-search-bar" style="display:none;padding:8px 16px;background:var(--bg-primary);border-top:1px solid var(--border);">
      <div style="display:flex;align-items:center;gap:8px;">
        <span class="icon icon-sm" style="color:var(--text-muted);" id="msg-search-icon"></span>
        <input type="text" id="msg-search-input" placeholder="Поиск по сообщениям..." style="flex:1;background:transparent;border:none;color:var(--text-primary);font-size:0.85rem;outline:none;">
        <button class="icon-btn" id="close-msg-search" style="width:28px;height:28px;">
          <span class="icon icon-sm" id="msg-search-close-icon"></span>
        </button>
      </div>
    </div>

    <div class="chat-input-area" id="chat-input-area">
      <button class="icon-btn" id="attach-btn" title="Прикрепить файл">
        <span class="icon" id="attach-icon"></span>
      </button>
      <div class="chat-input-wrapper">
        <input type="text" class="chat-input" id="message-input" placeholder="Сообщение...">
      </div>
      <button class="icon-btn" id="voice-btn" title="Голосовое сообщение">
        <span class="icon" id="voice-icon"></span>
      </button>
      <button class="send-btn" id="send-btn" title="Отправить">
        <span class="icon" id="send-icon"></span>
      </button>
    </div>

    <!-- Call Overlay -->
    <div id="group-call-overlay">
      <div class="call-main-area">
        <div class="call-top-bar">
          <h3 id="call-title">Звонок</h3>
          <button class="icon-btn" id="end-call-x-btn" title="Свернуть">
            <span class="icon" id="call-close-icon"></span>
          </button>
        </div>
        <div class="call-grid" id="call-grid"></div>
        <div class="call-sidebar">
          <h4>Участники (<span id="participant-count">0</span>)</h4>
          <div class="participant-list" id="participant-list"></div>
        </div>
      </div>
      <div class="call-controls-bar">
        <button class="control-btn" id="btn-mic" title="Микрофон">
          <span class="icon icon-lg" id="mic-icon"></span>
        </button>
        <button class="control-btn" id="btn-cam" title="Камера">
          <span class="icon icon-lg" id="cam-icon"></span>
        </button>
        <button class="control-btn" id="btn-screen" title="Демонстрация экрана">
          <span class="icon icon-lg" id="screen-icon"></span>
        </button>
        <button class="control-btn danger" id="btn-end-call" title="Завершить звонок">
          <span class="icon icon-lg" id="endcall-icon"></span>
        </button>
      </div>
    </div>
  </div>
</div>

